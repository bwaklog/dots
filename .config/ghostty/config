# theme = dark:GruvboxDarkHard,light:GruvboxLightHard
theme = rose-pine
theme = Kanagawa Dragon
theme = GruvboxDarkHard
# background = 000000
# background = 121215
background = 151617

# font-family = JetBrainsMono Nerd Font
font-family = JuliaMono 
# font-family = PragmataProMonoLiga Nerd Font 
font-size = 16

macos-titlebar-style = transparent
# window-decoration = false
unfocused-split-opacity = 0.50
split-divider-color=4F4F4F


# background-opacity = 0.94
# background-blur = true
# window-padding-x = 10
# window-padding-y = 10

window-position-x = 300
window-position-y = 70
resize-overlay = always

keybind = global:ctrl+q=toggle_quick_terminal
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+shift+k=goto_split:top

copy-on-select = true
quick-terminal-screen = mouse
quick-terminal-position = center
mouse-hide-while-typing = true
